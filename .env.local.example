UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash Architect advisor (home-page chatbox)
UPSTASH_BOX_API_KEY=          # Upstash Box — runs the extraction agent in isolation (LLM on Upstash's managed key)
# ARCHITECT_BOX_MODEL=anthropic/claude-sonnet-4-6   # optional model override

# Hackathon voting (/hackathon + /hackathon/summary) — uses the UPSTASH_REDIS_REST_* vars above.
# Admin password is stored as a SHA-256 hash (never plaintext). Default is the hash of
# "adminhackhaton2026!.". To use a different password, set the hex sha256 of it here:
#   node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PW').digest('hex'))"
# HACKATHON_ADMIN_PASSWORD_HASH=
